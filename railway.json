{
  "$schema": "https://json.schemastore.org/railway.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm run railway-start",
    "installCommand": "npm install"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}