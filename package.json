{
  "name": "princevchat",
  "version": "3.0.0",
  "description": "Free group voice chat - No signup, no download",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx watch server.ts\" \"vite --port 5173\"",
    "dev:server": "tsx watch server.ts",
    "dev:client": "vite --port 5173",
    "build": "vite build",
    "start": "npm run build && NODE_ENV=production tsx server.ts"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "tsx": "^4.7.0",
    "vite": "^5.0.12",
    "ws": "^8.16.0"
  }
}
